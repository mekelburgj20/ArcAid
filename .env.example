# ArcAid Beta Configuration Template

# --- Discord Beta Credentials ---
# Create a new bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN="your_arcaid_beta_bot_token"
DISCORD_CLIENT_ID="your_arcaid_beta_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_GUILD_ID="your_test_server_id"

# --- iScored Integration ---
# You can reuse your TableFlipper credentials or create a test game room.
ISCORED_USERNAME="your_iscored_username"
ISCORED_PASSWORD="your_iscored_password"
ISCORED_PUBLIC_URL="https://iscored.info/your_gameroom_id"

# --- Terminology Toggle ---
# "legacy" = Tables/Grinds (Pinball), "generic" = Games/Tournaments
TERMINOLOGY_MODE="legacy"

# --- Feature Toggles ---
REMOVE_HEADER_IMAGE=true
ENABLE_CALLOUTS=true
LOG_LEVEL=INFO

# --- Database ---
DB_PATH="./data/arcaid.db"
